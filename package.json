{
  "name": "pop-reminder",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client --lan",
    "start:expo-go": "expo start --go --lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node --import tsx --test config.release.test.js $(rg --files src -g '*.test.js' -g '*.spec.ts' -g '*.spec.tsx')",
    "biome:check": "biome check .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "mvh:feedback": "node scripts/mvh-feedback.mjs",
    "mvh:verify": "node scripts/mvh-guard-protected-files.mjs && pnpm run biome:check && pnpm test && pnpm run typecheck && pnpm run lint",
    "mvh:setup": "bash scripts/mvh-setup.sh",
    "verify:release": "pnpm test && pnpm run typecheck && pnpm run lint && pnpm run doctor && pnpm exec expo export --platform android --output-dir /private/tmp/pop-reminder-export-android && pnpm exec expo export --platform ios --output-dir /private/tmp/pop-reminder-export-ios",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "doctor": "expo-doctor"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.1.4",
    "@react-native-community/datetimepicker": "8.4.4",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.2",
    "expo": "~54.0.35",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-android-widget": "^0.20.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "^0.5.1",
    "zod": "^3.25.64",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/react": "~19.1.17",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "expo-doctor": "^1.20.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  }
}
