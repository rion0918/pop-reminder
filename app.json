{
  "expo": {
    "name": "ポップ・リマインダー",
    "slug": "pop-reminder",
    "scheme": "popreminder",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#EFF8FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rion0918.popreminder"
    },
    "android": {
      "package": "com.rion0918.popreminder"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
